# ═══════════════════════════════════════════════════════════════════════════════
# The Constitutional Atlas — Environment Variables
# Copy to pipeline/.env (pipeline) and app/.env.local (web app)
# NEVER commit .env or .env.local
# ═══════════════════════════════════════════════════════════════════════════════

# ── API Keys ─────────────────────────────────────────────────────────────────

# Google Gemini API key (required for M3 — Embedder)
GEMINI_API_KEY=your_gemini_api_key_here

# Neon PostgreSQL connection string
# Used by: pipeline/M4.5 (ingest) and app/ (search Route Handler)
# Format: postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
NEON_DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ── M1: Scraper ───────────────────────────────────────────────────────────────

SCRAPER_RATE_LIMIT_SECONDS=2
SCRAPER_MAX_RETRIES=3
# Set to true to enable Playwright headless fallback for JS-rendered pages
SCRAPER_USE_PLAYWRIGHT=false

# ── M3: Embedder ──────────────────────────────────────────────────────────────

EMBEDDING_MODEL=models/gemini-embedding-001
EMBEDDING_DIMENSIONS=768
EMBEDDING_TASK_TYPE=RETRIEVAL_DOCUMENT
EMBEDDING_BATCH_SIZE=100
# Requests per minute — free tier ~1500, paid tier up to 10000
EMBEDDING_MAX_RPM=1500
# Optional override for cost estimation in the final M3 report (USD / 1M tokens)
EMBEDDING_PRICE_PER_MILLION_TOKENS=0.15

# ── M4: Clusterer ─────────────────────────────────────────────────────────────

UMAP_N_NEIGHBORS_CLUSTER=30
UMAP_N_NEIGHBORS_VIZ=15
UMAP_MIN_DIST_CLUSTER=0.0
UMAP_MIN_DIST_VIZ=0.1
UMAP_METRIC=cosine
UMAP_RANDOM_STATE=42
HDBSCAN_MIN_CLUSTER_SIZE=10
HDBSCAN_MIN_SAMPLES=5
HDBSCAN_COUNTRY_MIN_CLUSTER_SIZE=3
HDBSCAN_COUNTRY_MIN_SAMPLES=2
