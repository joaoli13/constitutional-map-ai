# Constitutional Map — Web App environment variables
# Copy to .env.local — NEVER commit .env.local

# Neon PostgreSQL — used by /api/search Route Handler
# Use the @neondatabase/serverless HTTP driver (no TCP connection pool needed)
NEON_DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
