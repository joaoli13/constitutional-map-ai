# ═══════════════════════════════════════════════════════
# The Constitutional Atlas — .gitignore
# ═══════════════════════════════════════════════════════

# ── Secrets ─────────────────────────────────────────────
.env
.env.local
.env.*.local
*.pem

# ── Pipeline: data (never commit raw/intermediate data) ─
pipeline/data/raw/
pipeline/data/articles/
pipeline/data/embeddings/
pipeline/data/clusters/

# ── Pipeline: Python ─────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
.eggs/
dist/
build/
.venv/
venv/
.uv/

# ── Pipeline: Jupyter ────────────────────────────────────
.ipynb_checkpoints/
pipeline/notebooks/.ipynb_checkpoints/

# ── App: Next.js ─────────────────────────────────────────
app/.next/
app/out/
app/.vercel/

# app/public/data/ IS committed — generated by M4.5, served by Vercel CDN
# Exception: .gitkeep placeholder files are committed
!app/public/data/countries/.gitkeep

# ── App: Node ────────────────────────────────────────────
app/node_modules/
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── OS ───────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Editors ──────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
